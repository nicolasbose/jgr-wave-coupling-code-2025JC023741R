PROJECT 'ATMOSPHERE-WAVE COUPLING PORTO ILHA' ' '
 'ATMOSPHERE-WAVE COUPLING PORTO ILHA D01'
 'COMMENTS'
 
&&&&&&&&&&&&&&&&&&&&&&&&&&&& 
&&&	MODEL SETUP      &&&
&&&&&&&&&&&&&&&&&&&&&&&&&&&&

MODE NONSTATIONARY TWODIMENSIONAL

SET DEPMIN 0.10 INRHOG 0 NAUTICAL
COORD SPHERICAL

&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&& 
&&&	KEYWORD for number of nested SWAN grids.      &&&
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&

NSGRIDS 2

&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&&	KEYWORDS TO CREATE AND READ COMPUTATIONAL GRID 	&&&
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&

CGRID CURV 100 70 CIR 36 0.05 1 24 
READGRID COORDINATES 1 'Projects/Porto_ilha_202404/swan_domains/swan_grid_d01_east.dat' 4 0 0 FREE 

&&&&&&&&&&&&&&&&&&&&&&&&&&
&&	WIND INPUT	&&&
&&&&&&&&&&&&&&&&&&&&&&&&&&

INPGRID WIND REGular -39.0 -6 0 20 14 0.25 0.25 NONSTAT 20240401.000000 1 HR 20240430.230000
&READINP WIND 1 'Projects/Porto_ilha/wind_era5_wind_era5_rn.wnd' 4 0 FREE 

&WIND 10 90

&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&&	KEYWORDS TO CREATE AND READ BATHYMETRY GRID	 &&&
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&

INPGRID  BOTTOM CURV 0 0 100 70 EXC 9.999000e+003 
READINP BOTTOM -1 'Projects/Porto_ilha_202404/swan_domains/bathy_meqeast_d01.bot' 4 0 FREE 


&& CURRENT INPUT &&

&INPGRID CURRENT REGular -39.0 -6 0 60 42 0.083343505859375 0.08333587646484375 NONSTAT 20230601.000000 1 DAY 20230630.000000
&READINP CURRENT 1 'Projects/Porto_ilha/current_cmds_current_rn.dat' 4 0 FREE 


&& SSH INPUT &&

&INPGRID WLEV REGular -39.0 -6 0 60 42 0.083343505859375 0.08333587646484375 NONSTAT 20230601.003000 1 DAY 20230630.003000
&READINP WLEV 1 'ssh_cmds_ssh_rn.dat' 4 0 FREE 


&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
&&	WAVE BOUNDARY		&&& 
&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&

&BOUND SHAPESPEC JONSWAP MEAN DSPR DEGREES 

BOUNDSPEC SEGMENT IJ 100 1 100 10 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_e_0.spc2d 

BOUNDSPEC SEGMENT IJ 100 11 100 20 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_e_1.spc2d 

BOUNDSPEC SEGMENT IJ 100 21 100 30 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_e_2.spc2d 

BOUNDSPEC SEGMENT IJ 100 31 100 40 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_e_3.spc2d 

BOUNDSPEC SEGMENT IJ 100 41 100 50 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_e_4.spc2d 

BOUNDSPEC SEGMENT IJ 100 51 100 60 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_e_5.spc2d 

BOUNDSPEC SEGMENT IJ 100 61 100 70 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_e_6.spc2d 

BOUNDSPEC SEGMENT IJ 1 61 1 70 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_w_6.spc2d 

BOUNDSPEC SEGMENT IJ 81 1 90 1 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_s_8.spc2d 

BOUNDSPEC SEGMENT IJ 91 1 100 1 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_s_9.spc2d 

BOUNDSPEC SEGMENT IJ 1 70 10 70 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_n_0.spc2d 

BOUNDSPEC SEGMENT IJ 11 70 20 70 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_n_1.spc2d 

BOUNDSPEC SEGMENT IJ 21 70 30 70 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_n_2.spc2d 

BOUNDSPEC SEGMENT IJ 31 70 40 70 VARIABLE FILE 0 'Projects/Porto_ilha_202404/swan_domains/boundary_202404/specs_n_3.spc2d 

